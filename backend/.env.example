# Copy to .env as DATABASE_URL=...
#
# Prefer SESSION POOLER on IPv4 / Windows (direct db.* is IPv6-only):
#   Dashboard → Connect → Connection string → Type: URI → Method: Session pooler
#   Looks like: postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
#   https://supabase.com/docs/guides/database/connecting-to-postgres
#
# Transaction pooler (port 6543) is for serverless; SQLAlchemy on a long-running API should use session pooler.
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
